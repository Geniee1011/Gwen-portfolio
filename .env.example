# EmailJS configuration for the contact form.
# Create a free account at https://www.emailjs.com/, then add an email
# service + template and copy the IDs/keys below.
# Copy this file to ".env" (or ".env.local") and fill in your own values.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLICKEY=your_public_key
